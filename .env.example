# Copy this file to .env and fill in values for your environment.
# .env is gitignored and must never be committed.

# ---------------------------------------------------------------------------
# Backend — CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed request origins.
# Defaults to http://localhost:5173,http://127.0.0.1:5173 when unset (dev).
# Set to your production domain(s) before deploying.
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
