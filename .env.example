# Copy this file to .env and fill in values for your environment.
# .env is gitignored and must never be committed.

# ---------------------------------------------------------------------------
# Backend — CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed request origins.
# Defaults to http://localhost:5173,http://127.0.0.1:5173 when unset (dev).
# Set to your production domain(s) before deploying.
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ---------------------------------------------------------------------------
# Backend — Admin account (single admin, no registration)
# ---------------------------------------------------------------------------
# Credentials for the one admin account. Set these before deploying.
# Without these three variables the login endpoint returns 503.
# Generate a strong JWT_SECRET with: python -c "import secrets; print(secrets.token_hex(32))"
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=changeme
# JWT_SECRET=replace-with-a-long-random-secret

# ---------------------------------------------------------------------------
# Backend — AI Autofill (Gemini 2.0 Flash)
# ---------------------------------------------------------------------------
# Get a free API key at https://aistudio.google.com/apikey
# Without this key the "AI Autofill" button returns a 503 and is labelled
# as unavailable in the UI.
# GEMINI_API_KEY=AIza...
